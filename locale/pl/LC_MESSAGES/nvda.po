msgid "VolumeLocker"
msgstr "BlokadaGłośności"

msgid "Toggles the volume keys lock."
msgstr "Przełącza blokadę klawiszy głośności."

msgid "Volume locked"
msgstr "Głośność zablokowana"

msgid "Volume unlocked"
msgstr "Głośność odblokowana"

msgid "Blocks volume up key if locked."
msgstr "Blokuje klawisz zwiększania głośności, gdy aktywna jest blokada."

msgid "Blocks volume down key if locked."
msgstr "Blokuje klawisz zmniejszania głośności, gdy aktywna jest blokada."

msgid "Blocks volume mute key if locked."
msgstr "Blokuje klawisz wyciszania głośności, gdy aktywna jest blokada."
